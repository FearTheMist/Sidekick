{
  "name": "sidekick-ai-code-assistant",
  "displayName": "Sidekick - AI Code Assistant",
  "description": "A VS Code AI coding assistant with multi-session chat, inline completion, and configurable LLM providers.",
  "icon": "media/icon.png",
  "version": "0.0.8",
  "publisher": "Lydia",
  "repository":{
    "type": "git",
    "url": "https://github.com/FearTheMist/Sidekick"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:sidekick.testProviderConnection",
    "onCommand:sidekick.inlineDebugPing",
    "onCommand:sidekick.openInlineLogs",
    "onCommand:sidekick.openChat",
    "onView:sidekick.chatView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sidekick.openControlCenter",
        "title": "Sidekick: Open Control Center",
        "icon": {
          "light": "media/settings-light.svg",
          "dark": "media/settings-dark.svg"
        }
      },
      {
        "command": "sidekick.openChat",
        "title": "Sidekick: Open Chat"
      },
      {
        "command": "sidekick.openSettings",
        "title": "Sidekick: Open Settings",
        "icon": {
          "light": "media/settings-light.svg",
          "dark": "media/settings-dark.svg"
        }
      },
      {
        "command": "sidekick.openMcpManager",
        "title": "Sidekick: Open MCP Manager",
        "icon": {
          "light": "media/mcp-light.svg",
          "dark": "media/mcp-dark.svg"
        }
      },
      {
        "command": "sidekick.openPermissionSettings",
        "title": "Sidekick: Open Permission Settings"
      },
      {
        "command": "sidekick.explainCode",
        "title": "Sidekick: Explain Code"
      },
      {
        "command": "sidekick.refactorSelection",
        "title": "Sidekick: Refactor"
      },
      {
        "command": "sidekick.fixSelection",
        "title": "Sidekick: Fix Bugs"
      },
      {
        "command": "sidekick.addTestsSelection",
        "title": "Sidekick: Add Tests"
      },
      {
        "command": "sidekick.documentSelection",
        "title": "Sidekick: Document"
      },
      {
        "command": "sidekick.acceptInlinePart",
        "title": "Sidekick: Accept Next Inline Word"
      },
      {
        "command": "sidekick.rejectInline",
        "title": "Sidekick: Reject Inline Suggestion"
      },
      {
        "command": "sidekick.testProviderConnection",
        "title": "Sidekick: Test Provider Connection"
      },
      {
        "command": "sidekick.inlineDebugPing",
        "title": "Sidekick: Inline Debug Ping"
      },
      {
        "command": "sidekick.openInlineLogs",
        "title": "Sidekick: Open Inline Logs"
      },
      {
        "command": "sidekick.generateCommitMessage",
        "title": "Sidekick: Generate Commit Message",
        "icon": {
          "light": "media/generate-commit-light.svg",
          "dark": "media/generate-commit-dark.svg"
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sidekick",
          "title": "Sidekick",
          "icon": "media/sidekick-activity.svg"
        }
      ]
    },
    "views": {
      "sidekick": [
        {
          "id": "sidekick.chatView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "scm/title": [
        {
          "command": "sidekick.generateCommitMessage",
          "group": "navigation@40",
          "when": "scmProvider == git"
        }
      ],
      "editor/context": [
        {
          "command": "sidekick.explainCode",
          "group": "navigation@50",
          "when": "editorTextFocus"
        },
        {
          "command": "sidekick.refactorSelection",
          "group": "navigation@51",
          "when": "editorTextFocus"
        },
        {
          "command": "sidekick.fixSelection",
          "group": "navigation@52",
          "when": "editorTextFocus"
        },
        {
          "command": "sidekick.addTestsSelection",
          "group": "navigation@53",
          "when": "editorTextFocus"
        },
        {
          "command": "sidekick.documentSelection",
          "group": "navigation@54",
          "when": "editorTextFocus"
        }
      ],
      "view/title": [
        {
          "command": "sidekick.openControlCenter",
          "group": "navigation@90",
          "when": "view == sidekick.chatView"
        }
      ]
    },
    "keybindings": [
      {
        "command": "editor.action.inlineSuggest.commit",
        "key": "tab",
        "when": "inlineSuggestionVisible && textInputFocus"
      },
      {
        "command": "sidekick.rejectInline",
        "key": "escape",
        "when": "inlineSuggestionVisible && textInputFocus"
      },
      {
        "command": "sidekick.acceptInlinePart",
        "key": "ctrl+right",
        "mac": "cmd+right",
        "when": "inlineSuggestionVisible && textInputFocus"
      }
    ],
    "configuration": {
      "title": "Sidekick",
      "properties": {
        "sidekick.providers": {
          "type": "array",
          "default": [],
          "description": "Provider list. Supports openai-chat, openai-responses, openai-compatible, anthropic-messages."
        },
        "sidekick.completionProfile": {
          "type": "object",
          "default": {
            "providerId": "",
            "model": "",
            "temperature": 0.2,
            "maxTokens": 512
          },
          "description": "Model profile for inline completion."
        },
        "sidekick.chatProfile": {
          "type": "object",
          "default": {
            "providerId": "",
            "model": "",
            "temperature": 0.3,
            "maxTokens": 4096
          },
          "description": "Model profile for chat features."
        },
        "sidekick.agentProfile": {
          "type": "object",
          "default": {
            "providerId": "",
            "model": "",
            "temperature": 0.2,
            "maxTokens": 4096
          },
          "description": "Model profile for agent and tool calls."
        },
        "sidekick.mcpServers": {
          "type": "array",
          "default": [],
          "description": "Remote MCP servers over Streamable HTTP. Example: [{\"name\":\"acme\",\"url\":\"https://mcp.example.com/mcp\",\"headers\":{\"Authorization\":\"Bearer TOKEN\"},\"enabled\":true}]"
        },
        "sidekick.commitMessageLanguage": {
          "type": "string",
          "enum": [
            "auto",
            "zh-CN",
            "en"
          ],
          "default": "auto",
          "markdownDescription": "Language for generated commit messages. `auto` follows recent commit history when possible, otherwise infers from the diff.",
          "enumItemLabels": [
            "Auto",
            "中文",
            "English"
          ]
        },
        "sidekick.permissions": {
          "type": "object",
          "default": {
            "terminal_read": "allow",
            "terminal_project_exec": "ask",
            "terminal_project_mutation": "ask",
            "terminal_external_access": "ask",
            "terminal_network": "ask",
            "terminal_destructive": "ask"
          },
          "markdownDescription": "Default permission policy for Sidekick terminal command categories.",
          "properties": {
            "terminal_read": {
              "type": "string",
              "enum": [
                "allow",
                "ask",
                "deny"
              ],
              "description": "Read project state commands, such as git status or ls."
            },
            "terminal_project_exec": {
              "type": "string",
              "enum": [
                "allow",
                "ask",
                "deny"
              ],
              "description": "Project validation commands, such as npm test or pnpm build."
            },
            "terminal_project_mutation": {
              "type": "string",
              "enum": [
                "allow",
                "ask",
                "deny"
              ],
              "description": "Project-changing commands, such as npm install or git commit."
            },
            "terminal_external_access": {
              "type": "string",
              "enum": [
                "allow",
                "ask",
                "deny"
              ],
              "description": "Commands that access files outside the workspace."
            },
            "terminal_network": {
              "type": "string",
              "enum": [
                "allow",
                "ask",
                "deny"
              ],
              "description": "Commands that access the network, such as curl or wget."
            },
            "terminal_destructive": {
              "type": "string",
              "enum": [
                "allow",
                "ask",
                "deny"
              ],
              "description": "High-risk commands that may delete or overwrite data, or start nested shells."
            }
          }
        }
      }
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:gateway": "node scripts/gateway-acceptance.js"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}
